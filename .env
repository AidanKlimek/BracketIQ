# =============================================================================
# BracketIQ Environment Variables
# =============================================================================

# --- Data Source Config ---
# Torvik doesn't require auth, but we set a polite user-agent
USER_AGENT=BracketIQ/1.0 (--)

# --- ESPN API ---
# ESPN's public API doesn't require keys, but if rate-limited,
# you can throttle requests with this (seconds between calls)
ESPN_REQUEST_DELAY=1.0

# --- Torvik API ---
# Same — no key needed, but be respectful
TORVIK_REQUEST_DELAY=1.5

# --- Cache Settings ---
# How long (in hours) before cached data is considered stale
CACHE_TTL_HOURS=6

# --- Output ---
# Where to export CSVs (relative to project root)
EXPORT_DIR=exports

# --- Streamlit (Web UI) ---
# Port for the Streamlit web app
STREAMLIT_PORT=8501